      .tab-icon-wrap { display: flex; align-items: center; gap: 14px; }
      .tab-icon { width: 60px; height: 60px; font-size: 30px; margin: 0; }
      .why-grid { grid-template-columns: 1fr; gap: 44px; }
      .why-svg { order: -1; }
      .price-grid { grid-template-columns: 1fr; max-width: 380px; margin: 0 auto; }
      .contact-grid { grid-template-columns: 1fr; }
      .ci-side { padding-top: 0; }
