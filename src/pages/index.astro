---
const siteUrl = "https://atai.agency";
const pageTitle = "ATAI | Agentes de IA que trabajan por tu negocio, 24/7";
const pageDescription =
  "Automatiza operaciones, elimina trabajo manual y escala sin contratar. ATAI diseña agentes de IA, flujos automatizados y software a medida para empresas en Costa Rica y Latinoamérica.";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <link rel="canonical" href={siteUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.jpg`} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: "ATAI",
      url: siteUrl,
      logo: `${siteUrl}/logo.png`
    })}></script>

    <style is:global>
      :root {
        --bg: #0e0d0c;
        --text-primary: #0e0d0c;
        --text-alt: #f7f7f4;
        --text-muted: #8f8f8d;
        --line: rgba(247, 247, 244, 0.14);
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; font-family: Inter, sans-serif; background: var(--bg); color: var(--text-alt); }
      a { color: inherit; text-decoration: none; }
      .container { width: min(1240px, calc(100% - 2.4rem)); margin-inline: auto; }

      .skip { position: absolute; left: -9999px; top: 0; }
      .skip:focus { left: 1rem; top: 1rem; background: #fff; color: #111; padding: .4rem .7rem; border-radius: .4rem; }

      .navbar {
        position: sticky; top: 0; z-index: 20;
        background: rgba(247, 247, 244, 0.97);
        color: var(--text-primary);
        border-bottom: 1px solid #dddcd7;
        backdrop-filter: blur(10px);
      }
      .nav-inner {
        min-height: 74px;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 1.4rem;
      }
      .logo { font-weight: 800; letter-spacing: .02em; }
      .menu { display: flex; justify-content: center; gap: 1.2rem; font-size: .94rem; color: #3a3a3a; }
      .btn { display: inline-flex; align-items: center; justify-content: center; border-radius: .5rem; font-weight: 600; padding: .7rem 1rem; }
      .btn.dark { background: #0e0d0c; color: #f7f7f4; }
      .btn.light { background: #f1f1ed; color: #0f0f0f; border: 1px solid #cbc9c3; }
      .btn.ghost { border: 1px solid var(--line); color: var(--text-alt); background: transparent; }

      .hero {
        position: relative; min-height: 86vh; display: flex; align-items: center;
        border-bottom: 1px solid #252525; overflow: hidden;
      }
      .hero video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: .35; }
      .hero::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at center, rgba(14,13,12,.2), rgba(14,13,12,.86)); }
      .hero-content { position: relative; z-index: 1; text-align: center; width: 100%; }
      h1 { margin: 0 auto; max-width: 14ch; font-size: clamp(2.1rem, 5.6vw, 5.4rem); line-height: .96; }
      .hero-actions { margin-top: 1.2rem; display: flex; justify-content: center; gap: .65rem; flex-wrap: wrap; }
      .logo-strip {
        position: absolute; bottom: 1.2rem; left: 0; right: 0; z-index: 1;
        display: flex; justify-content: center; gap: .55rem; flex-wrap: wrap;
      }
      .pill {
        border: 1px solid rgba(247,247,244,.25); color: rgba(247,247,244,.86);
        background: rgba(14,13,12,.55); border-radius: 999px; padding: .42rem .7rem; font-size: .82rem;
      }

      .section { border-top: 1px solid #252525; padding: 6rem 0; }
      .header-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.2rem; margin-bottom: 2rem; }
      .tag { color: #9e9e99; text-transform: uppercase; letter-spacing: .13em; font-size: .72rem; font-weight: 700; margin-bottom: .8rem; }
      h2 { margin: 0; font-size: clamp(1.85rem, 3.1vw, 3.2rem); line-height: 1.08; max-width: 16ch; }
      .lead { margin: 0; color: #b4b4b0; line-height: 1.7; }

      .lines { border-top: 1px solid #2a2a2a; }
      .line {
        display: grid; grid-template-columns: 1fr auto; gap: 1rem;
        border-bottom: 1px solid #2a2a2a; padding: 1.2rem 0;
      }
      .line p { margin: 0; }
      .line span { color: #bcbcb8; font-variant-numeric: tabular-nums; }

      .results-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .95rem; }
      .result {
        min-height: 250px; border-radius: .9rem; border: 1px solid #2f2f2f;
        background: linear-gradient(180deg, #1a1a1a, #111); padding: 1rem;
        display: flex; flex-direction: column; justify-content: flex-end;
      }
      .result h3 { margin: 0 0 .25rem; }
      .result p { margin: 0; color: #c9c9c5; }

      .philo { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .95rem; }
      .philo-item { border: 1px solid #2d2d2d; border-radius: .8rem; padding: 1rem; background: rgba(255,255,255,.02); }
      .philo-item h3 { margin: 0 0 .4rem; }
      .philo-item p { margin: 0; color: #bebebb; line-height: 1.68; }

      .cta {
        margin-top: 2rem;
        border-radius: 1rem;
        background: #f1ede5;
        color: #121212;
        text-align: center;
        padding: 3rem 1.4rem;
      }
      .cta h2 { max-width: none; }

      .chips { display: flex; flex-wrap: wrap; gap: .55rem; margin-top: 1.4rem; }
      .chip {
        border: 1px solid #2f2f2f; border-radius: 999px; padding: .5rem .82rem;
        color: #d9dfeb; background: rgba(255,255,255,.03);
      }

      .form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .7rem; margin-top: 1.6rem; }
      input { font: inherit; border-radius: .65rem; border: 1px solid #373737; padding: .78rem; background: #090d14; color: #fff; }
      .msg { min-height: 1.2rem; margin-top: .5rem; color: #cbffde; }

      footer { border-top: 1px solid #2c2c2c; padding: 1.2rem 0 2rem; color: #a2a2a0; font-size: .92rem; }

      @media (max-width: 960px) {
        .menu { display: none; }
        .header-grid, .results-grid, .philo, .form { grid-template-columns: 1fr; }
        .hero { min-height: 72vh; }
      }
    </style>
  </head>

  <body>
    <a class="skip" href="#content">Saltar al contenido</a>

    <header class="navbar">
      <div class="container nav-inner">
        <a class="logo" href="#">ATAI</a>
        <nav class="menu" aria-label="Navegación principal">
          <a href="#expertise">Servicios</a>
          <a href="#platform">Cómo funciona</a>
          <a href="#results">Casos de uso</a>
          <a href="#philosophy">Por qué ATAI</a>
        </nav>
        <a class="btn light" href="#demo">Hablar con un experto</a>
      </div>
    </header>

    <main id="content">
      <section class="hero">
        <video autoplay muted loop playsinline>
          <source src="https://storage.googleapis.com/ew-assets/happyrobot/happyrobot-new-hero-video-only-new-2026-02.mp4" type="video/mp4" />
        </video>
        <div class="container hero-content">
          <h1>Tu negocio operando en piloto automático</h1>
          <div class="hero-actions">
            <a class="btn dark" href="#demo">Quiero automatizar mi negocio</a>
            <a class="btn ghost" href="#expertise">Ver qué hacemos</a>
          </div>
        </div>
        <div class="logo-strip">
          <span class="pill">OpenAI</span><span class="pill">Anthropic</span><span class="pill">LangChain</span><span class="pill">n8n</span><span class="pill">Make</span><span class="pill">AWS</span>
        </div>
      </section>

      <section id="expertise" class="section">
        <div class="container">
          <div class="header-grid">
            <div><p class="tag">nuestros servicios</p><h2>Cuatro formas de escalar tu operación</h2></div>
            <div><p class="lead">Diseñamos agentes que trabajan 24/7, automatizamos procesos que hoy consumen horas, y construimos el software que tu negocio necesita para crecer sin depender de más personal.</p><a href="#demo" class="btn dark" style="margin-top:1rem;">Quiero una consulta gratis</a></div>
          </div>
          <div class="lines">
            <div class="line"><p><strong>Agentes de IA:</strong> Asistentes autónomos que atienden clientes, gestionan tareas y toman decisiones sin que tú intervengas</p><span>01</span></div>
            <div class="line"><p><strong>Automatización de procesos:</strong> Conectamos tus herramientas y eliminamos el trabajo repetitivo con flujos inteligentes a medida</p><span>02</span></div>
            <div class="line"><p><strong>Diseño web premium:</strong> Sitios y apps que convierten visitas en clientes — rápidos, modernos y construidos para vender</p><span>03</span></div>
            <div class="line"><p><strong>Desarrollo de software:</strong> CRMs, dashboards, APIs y sistemas internos construidos exactamente como tu negocio los necesita</p><span>04</span></div>
          </div>
        </div>
      </section>

      <section id="platform" class="section">
        <div class="container">
          <div class="header-grid">
            <div><p class="tag">nuestro proceso</p><h2>De idea a resultados en semanas, no meses</h2></div>
            <p class="lead">Sin burocracia ni proyectos eternos. Arrancamos rápido, medimos desde el día uno y ajustamos hasta que los números hablen solos.</p>
          </div>
          <div class="lines">
            <div class="line"><p><strong>Diagnóstico:</strong> Analizamos tu operación e identificamos los puntos donde la automatización genera mayor impacto y retorno</p><span>01</span></div>
            <div class="line"><p><strong>Diseño:</strong> Construimos la arquitectura de la solución: qué herramientas, qué agentes, qué flujos — antes de escribir una sola línea de código</p><span>02</span></div>
            <div class="line"><p><strong>Construcción:</strong> Desarrollamos e integramos con lo que ya usas. Sin migrar todo, sin interrumpir tu operación actual</p><span>03</span></div>
            <div class="line"><p><strong>Escala:</strong> Monitoreamos, optimizamos y expandimos. Tu solución mejora con el tiempo sin que tengas que hacer nada</p><span>04</span></div>
          </div>
        </div>
      </section>

      <section id="results" class="section">
        <div class="container">
          <div class="header-grid">
            <div><p class="tag">casos de uso</p><h2>Resultados que se miden en dinero y tiempo</h2></div>
            <p class="lead">No vendemos tecnología. Vendemos horas recuperadas, costos reducidos y ventas que antes se perdían. Así se ven nuestras soluciones en la práctica.</p>
          </div>
          <div class="results-grid">
            <article class="result"><h3>E-commerce</h3><p>Agente que atiende pedidos, gestiona devoluciones y responde WhatsApp sin intervención humana — de día y de noche</p></article>
            <article class="result"><h3>Servicios profesionales</h3><p>Sistema que califica leads, envía cotizaciones y hace seguimiento automático hasta cerrar la venta o agendar la llamada</p></article>
            <article class="result"><h3>Empresas y pymes</h3><p>Dashboard con datos en tiempo real, alertas automáticas y reportes que antes tomaban horas en preparar</p></article>
          </div>
        </div>
      </section>

      <section id="philosophy" class="section">
        <div class="container">
          <div class="header-grid">
            <div><p class="tag">por qué ATAI</p><h2>No somos consultores. Somos constructores.</h2></div>
            <p class="lead">Muchas agencias te venden estrategia. Nosotros entregamos software que funciona, automatizaciones activas y resultados medibles desde la primera semana.</p>
          </div>
          <div class="philo">
            <article class="philo-item"><h3>Orientados a resultados</h3><p>Cada proyecto tiene KPIs claros. Si no podemos medir el impacto, no lo hacemos. Tu ROI es nuestra métrica de éxito.</p></article>
            <article class="philo-item"><h3>Implementación rápida</h3><p>De diagnóstico a producción en semanas. Sin proyectos de 6 meses ni propuestas que nunca terminan.</p></article>
            <article class="philo-item"><h3>Socios, no proveedores</h3><p>Seguimos con vos después del lanzamiento. Monitoreamos, optimizamos y escalamos según tu negocio crece.</p></article>
          </div>
        </div>
      </section>

      <section id="demo" class="container cta">
        <h2>¿Cuánto te cuesta no automatizar?</h2>
        <a class="btn dark" href="https://wa.me/50660173449" target="_blank" rel="noopener noreferrer">Agendar sesión gratuita de 30 min</a>
      </section>

      <section class="section">
        <div class="container">
          <h2>Trabajamos con todo tipo de negocio</h2>
          <div class="chips">
            <span class="chip">E-commerce</span><span class="chip">Agencias</span><span class="chip">Retail</span><span class="chip">Manufactura</span><span class="chip">Atención al Cliente</span><span class="chip">Ventas B2B</span><span class="chip">Operaciones</span><span class="chip">RRHH y Reclutamiento</span><span class="chip">Salud</span><span class="chip">Bienes raíces</span>
          </div>
          <form id="demoForm" class="form" aria-label="Formulario de contacto">
            <input type="text" name="name" placeholder="Tu nombre" required />
            <input type="email" name="email" placeholder="Tu correo" required />
            <button class="btn dark" type="submit">Solicitar diagnóstico gratis</button>
          </form>
          <p id="msg" class="msg" aria-live="polite"></p>
        </div>
      </section>
    </main>

    <footer>
      <div class="container">© 2025 ATAI · Automatización con Tecnología de Agentes Inteligentes · San José, Costa Rica 🇨🇷 · <a href="mailto:info@ataisolutions.com">info@ataisolutions.com</a> · <a href="https://wa.me/50660173449" target="_blank" rel="noopener noreferrer">+506 6017-3449</a></div>
    </footer>

    <script>
      const form = document.getElementById("demoForm");
      const msg = document.getElementById("msg");
      if (form && msg) {
        form.addEventListener("submit", (event) => {
          event.preventDefault();
          const data = new FormData(form);
          const name = data.get("name");
          msg.textContent = typeof name === "string" && name.trim() ? `Gracias, ${name}. Te contactaremos pronto.` : "Gracias. Te contactaremos pronto.";
          form.reset();
        });
      }
    </script>
  </body>
</html>
