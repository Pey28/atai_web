<script>
// PARTICLES
(function(){
  const c=document.getElementById('pcanvas'),x=c.getContext('2d');
  let pts=[],raf;
  function resize(){c.width=innerWidth;c.height=innerHeight;}
  function P(){this.x=Math.random()*c.width;this.y=Math.random()*c.height;this.vx=(Math.random()-.5)*.4;this.vy=(Math.random()-.5)*.4;this.r=Math.random()*1.8+.8;this.col=Math.random()>.5?'#6C63FF':'#00F5C4';this.a=Math.random()*.45+.15;}
  function init(){pts=[];const n=Math.min(48,Math.floor(c.width*c.height/18000));for(let i=0;i<n;i++)pts.push(new P());}
  function draw(){
    x.clearRect(0,0,c.width,c.height);
    pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<0||p.x>c.width)p.vx*=-1;if(p.y<0||p.y>c.height)p.vy*=-1;x.beginPath();x.arc(p.x,p.y,p.r,0,Math.PI*2);x.fillStyle=p.col;x.globalAlpha=p.a;x.fill();x.globalAlpha=1;});
    for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);if(d<145){x.beginPath();x.moveTo(pts[i].x,pts[i].y);x.lineTo(pts[j].x,pts[j].y);x.strokeStyle=`rgba(108,99,255,${(1-d/145)*.28})`;x.lineWidth=.5;x.stroke();}}
    raf=requestAnimationFrame(draw);
  }
  resize();init();draw();
  window.addEventListener('resize',()=>{resize();init();},{passive:true});
  document.addEventListener('visibilitychange',()=>{document.hidden?cancelAnimationFrame(raf):draw();});
})();

// NAVBAR
(function(){
  const nav=document.getElementById('nav');
  window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>50),{passive:true});
})();

// HAMBURGER
(function(){
  const btn=document.getElementById('hamburger'),menu=document.getElementById('mob-menu');
  btn.addEventListener('click',()=>{const o=btn.classList.toggle('open');btn.setAttribute('aria-expanded',o);menu.classList.toggle('open',o);});
  menu.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{btn.classList.remove('open');btn.setAttribute('aria-expanded','false');menu.classList.remove('open');}));
})();

// SCROLL SPY
(function(){
  const links=document.querySelectorAll('.nav-links a');
  document.querySelectorAll('section[id]').forEach(s=>{
    new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting)links.forEach(l=>l.classList.toggle('active',l.getAttribute('href')==='#'+e.target.id));}),{rootMargin:'-50% 0px -50% 0px'}).observe(s);
  });
})();

// FADE UP
(function(){
  const obs=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}}),{threshold:.1});
  document.querySelectorAll('.fade-up').forEach(el=>obs.observe(el));
})();

// COUNTERS
(function(){
  let done=false;
  const obs=new IntersectionObserver(entries=>{if(entries[0].isIntersecting&&!done){done=true;document.querySelectorAll('.stat-n').forEach(el=>{const t=+el.dataset.target,s=el.dataset.suffix||'',dur=1800,t0=performance.now();(function tick(now){const p=Math.min((now-t0)/dur,1),e=1-Math.pow(1-p,3);el.textContent=Math.floor(e*t)+s;if(p<1)requestAnimationFrame(tick);})(performance.now());});obs.disconnect();}},{threshold:.5});
  const h=document.getElementById('hero');if(h)obs.observe(h);
})();

// TABS
(function(){
  document.querySelectorAll('.tab-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      document.querySelectorAll('.tab-btn').forEach(b=>{b.classList.remove('active');b.setAttribute('aria-selected','false');});
      document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
      btn.classList.add('active');btn.setAttribute('aria-selected','true');
      const p=document.getElementById('tp-'+btn.dataset.tab);if(p)p.classList.add('active');
    });
  });
})();

// CAROUSEL
(function(){
  const track=document.getElementById('t-track'),dots=document.querySelectorAll('.c-dot');
  let cur=0,timer;
  function cw(){const c=track.querySelector('.t-card');return c?c.offsetWidth+24:0;}
  function go(i){cur=i;track.style.transform=`translateX(-${cw()*i}px)`;dots.forEach((d,j)=>d.classList.toggle('active',j===i));}
  function next(){go((cur+1)%dots.length);}
  dots.forEach((d,i)=>d.addEventListener('click',()=>{clearInterval(timer);go(i);timer=setInterval(next,4200);}));
  timer=setInterval(next,4200);
  window.addEventListener('resize',()=>go(cur),{passive:true});
})();

// FORM
(function(){
  const form=document.getElementById('cf');
  const ve=e=>/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e);
  const se=(id,err)=>{const el=document.getElementById('fg-'+id);if(el)el.classList.toggle('err',err);};
  form.addEventListener('submit',e=>{
    e.preventDefault();
    const n=document.getElementById('f-nombre').value.trim(),em=document.getElementById('f-email').value.trim(),msg=document.getElementById('f-msg').value.trim();
    se('nombre',!n);se('email',!ve(em));se('msg',!msg);
    if(n&&ve(em)&&msg){
      const btn=form.querySelector('button[type="submit"]');
      btn.textContent='✓ Mensaje enviado';btn.style.background='#00F5C4';btn.style.color='#0A0A0F';btn.disabled=true;
      setTimeout(()=>{form.reset();btn.disabled=false;btn.style.background='';btn.style.color='';btn.innerHTML='Enviar mensaje <i class="fa-solid fa-paper-plane" aria-hidden="true"></i>';},4000);
    }
  });
})();
</script>
