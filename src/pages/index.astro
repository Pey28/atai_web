---
const siteUrl = "https://atai.agency";
const pageTitle = "Chatbot · Diseño Web · Software a Medida en San Carlos, Costa Rica | ATAI Solutions";
const pageDescription =
  "Chatbot, diseño web y desarrollo de software a medida para empresas en San Carlos, Costa Rica. ATAI implementa agentes de IA, sitios web premium y sistemas que hacen crecer tu negocio. Consulta gratis.";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://assets.mixkit.co" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />

    <meta name="keywords" content="chatbot san carlos costa rica, diseño web san carlos costa rica, desarrollo de software costa rica, chatbot para empresas costa rica, agente de ia costa rica, automatización empresas san carlos, diseño web ciudad quesada, software a medida costa rica, whatsapp bot costa rica, inteligencia artificial negocios costa rica, paginas web profesionales costa rica" />
    <meta name="geo.region" content="CR-A" />
    <meta name="geo.placename" content="San Carlos, Alajuela, Costa Rica" />
    <meta name="geo.position" content="10.3267;-84.4270" />
    <meta name="ICBM" content="10.3267, -84.4270" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
    <meta property="og:locale" content="es_CR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.jpg`} />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": siteUrl,
      name: "ATAI Solutions",
      description: "Chatbot, diseño web y desarrollo de software a medida para empresas en San Carlos, Costa Rica. Automatización con inteligencia artificial.",
      url: siteUrl,
      logo: `${siteUrl}/logo.png`,
      image: `${siteUrl}/og-image.jpg`,
      telephone: "+50660173449",
      email: "info@ataisolutions.com",
      address: {
        "@type": "PostalAddress",
        addressLocality: "San Carlos",
        addressRegion: "Alajuela",
        addressCountry: "CR"
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 10.3267,
        longitude: -84.4270
      },
      areaServed: [
        { "@type": "City", name: "San Carlos" },
        { "@type": "City", name: "Ciudad Quesada" },
        { "@type": "Country", name: "Costa Rica" }
      ],
      priceRange: "$$",
      openingHours: "Mo-Fr 08:00-18:00",
      sameAs: ["https://wa.me/50660173449"],
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Servicios ATAI Solutions",
        itemListElement: [
          { "@type": "Offer", itemOffered: { "@type": "Service", name: "Chatbot para empresas en San Carlos Costa Rica" } },
          { "@type": "Offer", itemOffered: { "@type": "Service", name: "Diseño web profesional en San Carlos Costa Rica" } },
          { "@type": "Offer", itemOffered: { "@type": "Service", name: "Desarrollo de software a medida Costa Rica" } },
          { "@type": "Offer", itemOffered: { "@type": "Service", name: "Automatización de procesos empresariales" } }
        ]
      }
    })}></script>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "¿Qué es un chatbot para empresas en San Carlos, Costa Rica?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Un chatbot de voz es un agente de inteligencia artificial que atiende a tus clientes por voz, transcribe automáticamente cada conversación y gestiona tareas sin intervención humana, 24 horas al día, 7 días a la semana. ATAI implementa chatbots de voz a medida para negocios en San Carlos, Ciudad Quesada y toda Costa Rica."
          }
        },
        {
          "@type": "Question",
          name: "¿Hacen diseño web en San Carlos, Costa Rica?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Sí. ATAI Solutions diseña sitios web profesionales para empresas en San Carlos, Costa Rica. Creamos páginas web rápidas, modernas y optimizadas para Google, conectadas con chatbot y automatización para que su negocio venda más en línea."
          }
        },
        {
          "@type": "Question",
          name: "¿Qué es software a medida y para qué sirve en Costa Rica?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "El software a medida es un sistema desarrollado específicamente para tu negocio: CRMs, dashboards, aplicaciones de gestión, APIs e integraciones. ATAI desarrolla software a medida para empresas en Costa Rica que necesitan soluciones que los sistemas genéricos no cubren."
          }
        },
        {
          "@type": "Question",
          name: "¿Cómo puede un chatbot ayudar a mi negocio en San Carlos?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Un chatbot de voz puede atender llamadas, responder preguntas frecuentes, agendar citas, calificar leads y transcribir cada conversación automáticamente, sin que necesites personal adicional. Empresas en San Carlos ya están ahorrando horas de trabajo manual con nuestras soluciones."
          }
        },
        {
          "@type": "Question",
          name: "¿Cuánto cuesta el diseño web o un chatbot en Costa Rica?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "El costo depende del proyecto. ATAI ofrece una consulta gratuita para diagnosticar tu caso y entregarte una propuesta sin compromiso. Contáctanos por WhatsApp al +506 6017-3449 o escríbenos a info@ataisolutions.com."
          }
        },
        {
          "@type": "Question",
          name: "¿ATAI tiene servicio en San Carlos y Ciudad Quesada?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Sí. ATAI Solutions atiende empresas en San Carlos, Ciudad Quesada y toda la Zona Norte de Costa Rica. Ofrecemos chatbot, diseño web y software a medida de forma 100% remota, sin que tengas que desplazarte."
          }
        }
      ]
    })}></script>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: "ATAI SolutionsChatbot, Diseño Web y Software en San Carlos Costa Rica",
      description: "Chatbot, diseño web y software a medida para empresas en San Carlos, Costa Rica.",
      inLanguage: "es-CR"
    })}></script>

    <style is:global>
      :root {
        --bg: #0e0d0c;
        --text-primary: #0e0d0c;
        --text-alt: #f7f7f4;
        --text-muted: #8f8f8d;
        --line: rgba(247, 247, 244, 0.14);
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; font-family: Inter, sans-serif; background: var(--bg); color: var(--text-alt); }
      a { color: inherit; text-decoration: none; }
      .container { width: min(1240px, calc(100% - 2.4rem)); margin-inline: auto; }

      .skip { position: absolute; left: -9999px; top: 0; }
      .skip:focus { left: 1rem; top: 1rem; background: #fff; color: #111; padding: .4rem .7rem; border-radius: .4rem; }

      .navbar {
        position: sticky; top: 0; z-index: 20;
        background: rgba(14, 13, 12, 0.97);
        color: #f7f7f4;
        backdrop-filter: blur(10px);
      }
      .nav-inner {
        min-height: 74px;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 1.4rem;
      }
      .logo { font-weight: 800; letter-spacing: .02em; }
      .menu { display: flex; justify-content: center; gap: 1.2rem; font-size: .94rem; color: #c8c8c4; }
      .btn { display: inline-flex; align-items: center; justify-content: center; border-radius: .5rem; font-weight: 600; padding: .7rem 1rem; }
      .btn.dark { background: #0e0d0c; color: #f7f7f4; }
      .navbar .btn.dark { box-shadow: 0 0 18px rgba(204, 68, 255, 0.35), 0 0 36px rgba(0, 204, 204, 0.2); transition: box-shadow .3s; }
      .navbar .btn.dark:hover { box-shadow: 0 0 26px rgba(204, 68, 255, 0.55), 0 0 52px rgba(0, 204, 204, 0.35); }
      .btn.light { background: #f1f1ed; color: #0f0f0f; border: 1px solid #cbc9c3; }
      .btn.ghost { border: 1px solid var(--line); color: var(--text-alt); background: transparent; }

      .hero {
        position: relative; min-height: 86vh; display: flex; align-items: center;
        border-bottom: 1px solid #252525; overflow: hidden;
      }
      .hero video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: .85; }
      .hero::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at center, rgba(14,13,12,.15), rgba(14,13,12,.55)); }
      .hero-content { position: relative; z-index: 1; text-align: center; width: 100%; }
      h1 { margin: 0 auto; max-width: 14ch; font-size: clamp(2.1rem, 5.6vw, 5.4rem); line-height: .96; text-shadow: 0 2px 20px rgba(0,0,0,.8); }
      .hero-content p { text-shadow: 0 1px 12px rgba(0,0,0,.7); }
      .hero-actions { margin-top: 1.2rem; display: flex; justify-content: center; gap: .65rem; flex-wrap: wrap; }
      .logo-strip {
        position: absolute; bottom: 1.2rem; left: 0; right: 0; z-index: 1;
        display: flex; justify-content: center; gap: .55rem; flex-wrap: wrap;
      }
      .pill {
        border: 1px solid rgba(247,247,244,.25); color: rgba(247,247,244,.86);
        background: rgba(14,13,12,.55); border-radius: 999px; padding: .42rem .7rem; font-size: .82rem;
      }

      .section { border-top: 1px solid #252525; padding: 6rem 0; text-align: center; }
      .header-grid { display: flex; flex-direction: column; align-items: center; gap: 1.2rem; margin-bottom: 2rem; }
      .tag { color: #9e9e99; text-transform: uppercase; letter-spacing: .13em; font-size: .72rem; font-weight: 700; margin-bottom: .8rem; }
      h2 { margin: 0 auto; font-size: clamp(1.85rem, 3.1vw, 3.2rem); line-height: 1.08; max-width: 22ch; text-align: center; }
      .lead { margin: 0 auto; color: #b4b4b0; line-height: 1.7; max-width: 54ch; text-align: center; }
      .header-grid .btn { align-self: center; margin-top: .4rem; }

      .lines { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: .9rem; }
      .lines .line:last-child:nth-child(odd) { grid-column: 1 / -1; max-width: calc(50% - .45rem); margin-inline: auto; width: 100%; }
      .line {
        border: 1px solid #2d2d2d; border-radius: .85rem;
        padding: 1.5rem 1.6rem; background: rgba(255,255,255,.03);
        box-shadow: 0 4px 22px rgba(0,0,0,.32);
        transition: transform .25s, box-shadow .25s, border-color .25s, background .25s;
      }
      .line:hover { transform: translateY(-5px); box-shadow: 0 10px 36px rgba(0,0,0,.52); border-color: rgba(0,245,196,.22); background: rgba(255,255,255,.055); }
      .line p { margin: 0; line-height: 1.65; }

      .results-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.2rem;
      }
      .result {
        position: relative;
        min-height: clamp(260px, 42vw, 340px);
        margin: 0;
        padding: 0;
        border: none;
        border-radius: .85rem;
        background-color: #1a1a1a;
        background-image: var(--result-img);
        background-size: cover;
        background-position: center;
        overflow: hidden;
        box-shadow: 0 6px 28px rgba(0,0,0,.45);
        transition: transform .3s, box-shadow .3s;
      }
      .result:hover { transform: translateY(-6px) scale(1.012); box-shadow: 0 16px 48px rgba(0,0,0,.65); }
      .result::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(14, 13, 12, 0.1) 0%, rgba(14, 13, 12, 0.45) 45%, rgba(14, 13, 12, 0.82) 100%);
        pointer-events: none;
      }
      .result-hit {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: flex-start;
        min-height: clamp(260px, 42vw, 340px);
        height: 100%;
        padding: 1.1rem 1.2rem 1.35rem;
        color: #f7f7f4;
        text-align: left;
        transition: color 0.2s;
      }
      .result-hit:hover { color: #fff; }
      .result-hit:focus-visible { outline: 2px solid #00f5c4; outline-offset: 3px; }
      .result-head {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.65rem;
        width: 100%;
      }
      .result-brand {
        min-width: 0;
        filter: drop-shadow(0 2px 14px rgba(0, 0, 0, 0.4));
      }
      .result-brand svg { display: block; height: auto; width: min(118px, 34vw); }
      .result-icon-fa {
        flex-shrink: 0;
        width: 42px;
        height: 42px;
        border-radius: 0.55rem;
        background: rgba(14, 13, 12, 0.45);
        border: 1px solid rgba(247, 247, 244, 0.22);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.05rem;
        color: rgba(247, 247, 244, 0.95);
        backdrop-filter: blur(8px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.22);
      }
      .result-hit:hover .result-icon-fa {
        border-color: rgba(0, 245, 196, 0.4);
        color: #fff;
      }
      .result-body {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }
      .result-title {
        margin: 0;
        font-family: Georgia, "Times New Roman", Times, serif;
        font-weight: 500;
        font-size: clamp(1.15rem, 2.2vw, 1.55rem);
        line-height: 1.2;
        max-width: 22ch;
        text-shadow: 0 2px 28px rgba(0, 0, 0, 0.55);
      }
      .result-hit p {
        margin: 0.55rem 0 0;
        font-size: 0.86rem;
        line-height: 1.55;
        color: rgba(247, 247, 244, 0.9);
        max-width: 48ch;
        text-shadow: 0 1px 14px rgba(0, 0, 0, 0.45);
      }
      .result-more {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        margin-top: 1rem;
        padding: 0.45rem 0.85rem;
        border: 1px solid rgba(247, 247, 244, 0.45);
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: rgba(247, 247, 244, 0.95);
        background: rgba(14, 13, 12, 0.2);
        backdrop-filter: blur(6px);
        transition: border-color 0.2s, background 0.2s;
      }
      .result-hit:hover .result-more {
        border-color: rgba(247, 247, 244, 0.75);
        background: rgba(247, 247, 244, 0.12);
      }

      .philo { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .95rem; }
      .philo-item { border: 1px solid #2d2d2d; border-radius: .8rem; padding: 1rem; background: rgba(255,255,255,.02); box-shadow: 0 4px 24px rgba(0,0,0,.35); transition: transform .25s, box-shadow .25s, border-color .25s; }
      .philo-item:hover { transform: translateY(-5px); box-shadow: 0 10px 36px rgba(0,0,0,.55); border-color: rgba(0,245,196,.25); }
      .philo-item h3 { margin: 0 0 .4rem; }
      .philo-item p { margin: 0; color: #bebebb; line-height: 1.68; }

      .cta {
        margin-top: 2rem;
        border-radius: 1rem;
        background: #f1ede5;
        color: #121212;
        text-align: center;
        padding: 3rem 1.4rem;
      }
      .cta h2 { max-width: none; }

      .chips { display: flex; flex-wrap: wrap; gap: .55rem; margin-top: 1.4rem; }
      .chip {
        border: 1px solid #2f2f2f; border-radius: 999px; padding: .5rem .82rem;
        color: #d9dfeb; background: rgba(255,255,255,.03);
        box-shadow: 0 2px 10px rgba(0,0,0,.25); transition: transform .2s, box-shadow .2s, border-color .2s;
        cursor: default;
      }
      .chip:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,.4); border-color: rgba(0,245,196,.3); }

      .form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .7rem; margin-top: 1.6rem; }
      input { font: inherit; border-radius: .65rem; border: 1px solid #373737; padding: .78rem; background: #090d14; color: #fff; }
      .msg { min-height: 1.2rem; margin-top: .5rem; color: #cbffde; }

      footer { border-top: 1px solid #2c2c2c; padding: 1.2rem 0 2rem; color: #a2a2a0; font-size: .92rem; }

      .reveal {
        opacity: 0;
        transform: translateY(32px);
        transition: opacity .65s ease, transform .65s ease;
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-delay-1 { transition-delay: .1s; }
      .reveal-delay-2 { transition-delay: .2s; }
      .reveal-delay-3 { transition-delay: .32s; }
      .reveal-delay-4 { transition-delay: .44s; }

      @keyframes logo-fade-in {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
      #logo-bar {
        opacity: 0;
        animation: logo-fade-in .5s ease forwards;
        animation-delay: .7s;
      }
      #logo-solutions {
        opacity: 0;
        animation: logo-fade-in .6s ease forwards;
        animation-delay: 1.1s;
      }

      .wa-btn { position: fixed; bottom: 24px; right: 24px; z-index: 999; width: 58px; height: 58px; background: #25D366; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 20px rgba(37,211,102,.45); transition: transform .2s, box-shadow .2s; }
      .wa-btn:hover { transform: scale(1.1); box-shadow: 0 6px 28px rgba(37,211,102,.6); }
      .wa-btn svg { width: 30px; height: 30px; fill: #fff; }

      .stack-band {
        background: linear-gradient(165deg, #f4f1ea 0%, #e6e2d8 48%, #ded9cf 100%);
        color: #0e0d0c;
        border-top: 1px solid #cfc9be;
        border-bottom: 1px solid #cfc9be;
        padding: clamp(3.5rem, 8vw, 5.5rem) 0;
      }
      .stack-split {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.08fr);
        gap: clamp(1.5rem, 4vw, 3.5rem);
        align-items: center;
        text-align: left;
      }
      .stack-copy .tag { color: #5a5852; }
      .stack-copy h2 {
        margin: 0 0 1rem;
        font-family: Georgia, "Times New Roman", Times, serif;
        font-weight: 600;
        font-size: clamp(1.75rem, 2.8vw, 2.65rem);
        line-height: 1.12;
        max-width: 20ch;
        text-align: left;
        color: #0e0d0c;
      }
      .stack-copy .lead {
        margin: 0;
        max-width: 42ch;
        text-align: left;
        color: #3a3834;
        font-size: 1.02rem;
      }
      .stack-copy .btn { margin-top: 1.35rem; align-self: flex-start; }
      .stack-steps { margin: 2rem 0 0; padding: 0; list-style: none; }
      .stack-steps li {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.85rem 1rem;
        padding: 1rem 0;
        border-top: 1px solid rgba(14, 13, 12, 0.1);
      }
      .stack-steps li:first-child { border-top: 0; padding-top: 0; }
      .stack-steps .n {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        color: #7a766c;
        padding-top: 0.15rem;
      }
      .stack-steps strong { display: block; font-size: 0.98rem; margin-bottom: 0.25rem; }
      .stack-steps p { margin: 0; font-size: 0.92rem; line-height: 1.55; color: #4a4840; }
      .stack-visual {
        position: relative;
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.35);
        border: 1px solid rgba(14, 13, 12, 0.08);
        box-shadow: 0 18px 48px rgba(14, 13, 12, 0.06);
        padding: 0.6rem;
      }
      .stack-svg { display: block; width: 100%; height: auto; max-height: min(420px, 52vh); }

      .sl { opacity: 0; transform: perspective(700px) rotateX(22deg) translateY(50px); transform-origin: center bottom; transition: opacity .9s ease, transform .9s cubic-bezier(.25,.46,.45,.94); }
      .sl.sl-visible { opacity: 1; transform: perspective(700px) rotateX(0deg) translateY(0); }

      @media (max-width: 960px) {
        .menu { display: none; }
        .nav-inner { grid-template-columns: auto auto; justify-content: space-between; }
        .header-grid, .results-grid, .philo, .form, .lines { grid-template-columns: 1fr; }
        .lines .line:last-child:nth-child(odd) { max-width: 100%; }
        .hero { min-height: 72vh; }
        .section { padding: 3.5rem 0; }
        .stack-split { grid-template-columns: 1fr; }
        .stack-copy h2 { max-width: none; }
        .stack-visual { order: -1; }
        .philo { grid-template-columns: 1fr; }
        .cta { padding: 2rem 1rem; border-radius: .75rem; }
        .result { min-height: 220px; }
        .result-hit { min-height: 220px; }
      }

      @media (max-width: 480px) {
        .navbar .btn.dark { font-size: .82rem; padding: .55rem .75rem; }
        h1 { font-size: clamp(2rem, 11vw, 3rem); }
        h2 { font-size: clamp(1.5rem, 7vw, 2.2rem); }
        .hero-actions { flex-direction: column; align-items: center; }
        .hero-actions .btn { width: 100%; max-width: 300px; justify-content: center; }
        .form { grid-template-columns: 1fr; }
        .results-grid { gap: .7rem; }
        .lines { gap: .65rem; }
        footer { font-size: .8rem; text-align: center; }
        footer .container { display: flex; flex-direction: column; gap: .4rem; align-items: center; }
      }
    </style>
  </head>

  <body>
    <a class="skip" href="#content">Saltar al contenido</a>

