    <script>
      const heroSources = [
        "https://assets.mixkit.co/videos/242/242-720.mp4",
        "https://assets.mixkit.co/videos/1732/1732-720.mp4",
        "https://assets.mixkit.co/videos/23282/23282-720.mp4",
      ];
      const heroVideo = document.getElementById("heroVideo");
      let heroIndex = 0;
      const prefetched = new Set();

      const prefetchHero = (url) => {
        if (prefetched.has(url)) return;
        prefetched.add(url);
        const link = document.createElement("link");
        link.rel = "prefetch";
        link.href = url;
        document.head.appendChild(link);
      };

      if (heroVideo) {
        const playHeroClip = () => {
          heroVideo.src = heroSources[heroIndex];
          heroVideo.load();
          heroVideo.play().catch(() => {});
        };

        heroVideo.addEventListener("ended", () => {
          heroIndex = (heroIndex + 1) % heroSources.length;
          prefetchHero(heroSources[(heroIndex + 1) % heroSources.length]);
          playHeroClip();
        });

        heroVideo.addEventListener("playing", () => {
          prefetchHero(heroSources[(heroIndex + 1) % heroSources.length]);
        });

        const startHero = () => {
          heroIndex = 0;
          prefetchHero(heroSources[1]);
          playHeroClip();
        };

        const skipVideo =
          typeof navigator !== "undefined" &&
          Boolean(navigator.connection && "saveData" in navigator.connection && navigator.connection.saveData);
        const reduceMotion =
          typeof window !== "undefined" &&
          window.matchMedia &&
          window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (!skipVideo && !reduceMotion) {
          const deferHeroBoot = () => {
            const run = () => startHero();
            if ("requestIdleCallback" in window) {
              window.requestIdleCallback(run, { timeout: 2200 });
            } else {
              setTimeout(run, 400);
            }
          };
          if (document.readyState === "complete") {
            deferHeroBoot();
          } else {
            window.addEventListener("load", deferHeroBoot);
          }
        }
      }

      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });
      document.querySelectorAll(".reveal").forEach(el => revealObserver.observe(el));

      const stackVisual = document.getElementById("stackVisual");
      if (stackVisual) {
        const layers = stackVisual.querySelectorAll(".sl");
        const triggerPoints = [0.05, 0.3, 0.55, 0.78];
        const checkStack = () => {
          const rect = stackVisual.getBoundingClientRect();
          const vh = window.innerHeight;
          const progress = 1 - (rect.bottom / (vh + rect.height));
          layers.forEach((el, i) => {
            if (progress >= triggerPoints[i]) el.classList.add("sl-visible");
          });
        };
        window.addEventListener("scroll", checkStack, { passive: true });
        checkStack();
      }

      const form = document.getElementById("demoForm");
      const msg = document.getElementById("msg");
      if (form && msg) {
        form.addEventListener("submit", (event) => {
          event.preventDefault();
          const data = new FormData(form);
          const name = data.get("name");
          msg.textContent = typeof name === "string" && name.trim() ? `Gracias, ${name}. Te contactaremos pronto.` : "Gracias. Te contactaremos pronto.";
          form.reset();
        });
      }
    </script>
  </body>
</html>
